{
  "name": "@clipboard-health/groundcrew-config",
  "version": "1.2.7",
  "description": "Interactive TUI to create and update groundcrew's crew.config.json",
  "license": "MIT",
  "type": "module",
  "bin": {
    "crew-config": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "node --import tsx src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "bump": "npm version minor --no-git-tag-version",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@clipboard-health/groundcrew": "^4.46.5",
    "cosmiconfig": "^9.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
